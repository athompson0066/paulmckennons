# VITE_YOUTUBE_API_KEY: YouTube Data API v3 key (frontend calls YouTube directly)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# NOTE: No backend server needed on Vercel.
# Chat goes directly to Flowise from frontend.
# YouTube goes directly to Google API from frontend.
